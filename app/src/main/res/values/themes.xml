<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ───── Shared base ───── -->
    <style name="Theme.Kitabu.Base" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">@font/inter_regular</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════
         1. NOIR  — deep purple-black (original)
    ═══════════════════════════════════════════════════════════ -->
    <style name="Theme.Kitabu.Noir" parent="Theme.Kitabu.Base">
        <item name="colorPrimary">#C8A2FF</item>
        <item name="colorOnPrimary">#111118</item>
        <item name="colorSurface">#1E1E2E</item>
        <item name="colorOnSurface">#F0F0F8</item>
        <item name="colorSurfaceVariant">#252535</item>
        <item name="android:colorBackground">#111118</item>
        <item name="android:statusBarColor">#111118</item>
        <item name="android:navigationBarColor">#111118</item>
        <item name="kitabu_bg_primary">@color/noir_bg_primary</item>
        <item name="kitabu_bg_surface">@color/noir_bg_surface</item>
        <item name="kitabu_bg_elevated">@color/noir_bg_elevated</item>
        <item name="kitabu_accent">@color/noir_accent</item>
        <item name="kitabu_text_primary">@color/noir_text_primary</item>
        <item name="kitabu_text_secondary">@color/noir_text_secondary</item>
        <item name="kitabu_text_hint">@color/noir_text_hint</item>
        <item name="kitabu_divider">@color/noir_divider</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════
         2. MIDNIGHT  — pure AMOLED black + electric blue
    ═══════════════════════════════════════════════════════════ -->
