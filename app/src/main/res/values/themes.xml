    <!-- ═══════════════════════════════════════════════════════════
         8. SLATE  — desaturated blue-grey + cyan
    ═══════════════════════════════════════════════════════════ -->
    <style name="Theme.Kitabu.Slate" parent="Theme.Kitabu.Base">
        <item name="colorPrimary">#80DEEA</item>
        <item name="colorOnPrimary">#0A1215</item>
        <item name="colorSurface">#151C20</item>
        <item name="colorOnSurface">#E0F2F4</item>
        <item name="colorSurfaceVariant">#1E272C</item>
        <item name="android:colorBackground">#0D1317</item>
        <item name="android:statusBarColor">#0D1317</item>
