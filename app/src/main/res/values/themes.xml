        <item name="colorPrimary">#4FC3F7</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSurface">#0D0D0D</item>
        <item name="colorOnSurface">#E8F4FD</item>
        <item name="colorSurfaceVariant">#161616</item>
        <item name="android:colorBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="kitabu_bg_primary">@color/midnight_bg_primary</item>
        <item name="kitabu_bg_surface">@color/midnight_bg_surface</item>
        <item name="kitabu_bg_elevated">@color/midnight_bg_elevated</item>
        <item name="kitabu_accent">@color/midnight_accent</item>
        <item name="kitabu_text_primary">@color/midnight_text_primary</item>
        <item name="kitabu_text_secondary">@color/midnight_text_secondary</item>
        <item name="kitabu_text_hint">@color/midnight_text_hint</item>
        <item name="kitabu_divider">@color/midnight_divider</item>
