    </style>

    <!-- ── Default alias — manifest references this ── -->
    <style name="Theme.Kitabu" parent="Theme.Kitabu.Noir"/>

    <!-- ── Dialogs + overlays (theme-neutral) ── -->
    <style name="KitabuTitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">?attr/kitabu_text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">@font/inter_semibold</item>
    </style>

    <style name="KitabuDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">?attr/kitabu_bg_elevated</item>
        <item name="colorOnSurface">?attr/kitabu_text_primary</item>
        <item name="android:textColor">?attr/kitabu_text_primary</item>
    </style>

    <style name="KitabuBottomSheet" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/KitabuBottomSheetStyle</item>
    </style>

    <style name="KitabuBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">?attr/kitabu_bg_surface</item>
    </style>

    <style name="KitabuNavView" parent="Widget.MaterialComponents.NavigationView">
        <item name="android:background">?attr/kitabu_bg_surface</item>
        <item name="itemTextColor">?attr/kitabu_text_primary</item>
        <item name="itemIconTint">?attr/kitabu_accent</item>
    </style>

</resources>
