    <!-- Default alias -->
    <style name="Theme.Kitabu" parent="Theme.Kitabu.Noir"/>

    <!-- Dialogs + overlays -->
    <style name="KitabuTitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">@color/noir_text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="KitabuSubtitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Subtitle">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="KitabuDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/noir_bg_elevated</item>
        <item name="colorOnSurface">@color/noir_text_primary</item>
        <item name="android:textColor">@color/noir_text_primary</item>
    </style>

    <style name="KitabuBottomSheet" parent="Theme.Material3.Dark.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/KitabuBottomSheetStyle</item>
    </style>

    <style name="KitabuBottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/noir_bg_surface</item>
    </style>

    <style name="KitabuNavView" parent="Widget.MaterialComponents.NavigationView">
        <item name="android:background">@color/noir_bg_surface</item>
        <item name="itemTextColor">@color/noir_text_primary</item>
        <item name="itemIconTint">@color/noir_accent</item>
    </style>

    <!-- Light Theme Base -->
    <style name="Theme.Kitabu.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:statusBarColor">#F5F5F5</item>
        <item name="android:navigationBarColor">#F5F5F5</item>
        <item name="android:windowBackground">#FAFAFA</item>
        <item name="android:colorBackground">#FAFAFA</item>
        <item name="android:textColorPrimary">#1A1A2E</item>
        <item name="android:textColorSecondary">#555566</item>
    </style>

