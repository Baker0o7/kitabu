<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_surface"
        app:titleTextColor="@color/text_primary"
        app:subtitleTextColor="@color/text_hint"
        app:navigationIconTint="@color/text_primary"/>

    <!-- Quick action chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="@color/bg_primary">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSummarise"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📝 Summarise"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:paddingHorizontal="14dp"
                app:cornerRadius="18dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp"
                android:textColor="@color/accent"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExpand"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="✨ Expand"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:paddingHorizontal="14dp"
                app:cornerRadius="18dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp"
                android:textColor="@color/accent"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRewrite"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🔄 Rewrite"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:paddingHorizontal="14dp"
                app:cornerRadius="18dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp"
                android:textColor="@color/accent"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFlashcards"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🃏 Flashcards"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:paddingHorizontal="14dp"
                app:cornerRadius="18dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp"
                android:textColor="@color/accent"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTags"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🏷 Tags"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:paddingHorizontal="14dp"
                app:cornerRadius="18dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp"
                android:textColor="@color/accent"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOutline"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📋 Outline"
                android:textSize="12sp"
                android:paddingHorizontal="14dp"
                app:cornerRadius="18dp"
                app:strokeColor="@color/accent"
                app:strokeWidth="1dp"
                android:textColor="@color/accent"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Chat area -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">
        <TextView
            android:id="@+id/tvChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.6"
            android:paddingBottom="16dp"
            android:fontFamily="sans-serif"/>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/accent"
        android:visibility="gone"/>

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/bg_surface">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="24dp"
            app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp"
            app:boxCornerRadiusBottomEnd="24dp"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="1dp"
            app:boxStrokeColor="@color/accent"
            android:hintTextColor="@color/text_hint"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ask anything…"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:background="@android:color/transparent"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                android:fontFamily="sans-serif"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_send"
            app:backgroundTint="@color/accent"
            app:tint="@color/bg_primary"
            app:fabCustomSize="48dp"
            app:fabSize="mini"
            app:borderWidth="0dp"
            android:contentDescription="Send"
            app:elevation="2dp"/>

    </LinearLayout>
</LinearLayout>
