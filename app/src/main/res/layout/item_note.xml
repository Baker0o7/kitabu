<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardNote"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="@color/white_05">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left accent strip -->
        <View
            android:id="@+id/accentStrip"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Top row: icons + word count -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <CheckBox
                    android:id="@+id/checkboxSelect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:buttonTint="@color/accent"/>

                <ImageView
                    android:id="@+id/ivDragHandle"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="@color/text_hint"
                    android:visibility="gone"
                    android:layout_marginEnd="6dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="start|center_vertical">

                    <ImageView
                        android:id="@+id/ivPin"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_pin_filled"
                        android:tint="@color/accent"
                        android:visibility="gone"/>

                    <ImageView
                        android:id="@+id/ivLock"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_lock"
                        android:tint="@color/text_hint"
                        android:visibility="gone"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- Word count pill -->
                <TextView
                    android:id="@+id/tvWordCount"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:paddingHorizontal="8dp"
                    android:gravity="center"
                    android:background="@color/white_05"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:visibility="gone"
                    android:fontFamily="sans-serif-medium"/>

            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="4dp"/>

            <!-- Content preview -->
            <TextView
                android:id="@+id/tvContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif"
                android:maxLines="5"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.4"/>

            <!-- Tag chips -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:chipSpacingVertical="2dp"
                app:chipSpacingHorizontal="4dp"/>

            <!-- Date -->
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:fontFamily="sans-serif"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
